sub-fanet-distdir: FORCE
	@test -d fanet/ || mkdir -p fanet/
	cd fanet/ && ( test -e Makefile || $(QMAKE) -o Makefile /home/colin/fanet-ns3-ss/fanet/fanet.pro CONFIG+=release ) && $(MAKE) -e -f Makefile distdir DISTDIR=$(DISTDIR)/fanet

sub-test-distdir: FORCE
	@test -d test/ || mkdir -p test/
	cd test/ && ( test -e Makefile || $(QMAKE) -o Makefile /home/colin/fanet-ns3-ss/test/test.pro CONFIG+=release ) && $(MAKE) -e -f Makefile distdir DISTDIR=$(DISTDIR)/test

